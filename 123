-- ==============================
-- Module: Health Bar
-- ==============================

local function updateHealth(drawings, pos, size, character)
    if not ESPConfig.Health then
        drawings.healthBg.Visible  = false
        drawings.healthBar.Visible = false
        return
    end

    local hp, maxHp = getHealth(character)
    if not hp or not maxHp or maxHp == 0 then
        drawings.healthBg.Visible  = false
        drawings.healthBar.Visible = false
        return
    end

    local percent   = math.clamp(hp / maxHp, 0, 1)
    local barWidth  = 3
    local gap       = 2
    local barHeight = size.Y
    local bgX       = pos.X - barWidth - gap
    local bgY       = pos.Y

    drawings.healthBg.Position = Vector2.new(bgX, bgY)
    drawings.healthBg.Size     = Vector2.new(barWidth, barHeight)
    drawings.healthBg.Visible  = true

    local fillHeight = barHeight * percent
    drawings.healthBar.Position = Vector2.new(bgX, bgY + (barHeight - fillHeight))
    drawings.healthBar.Size     = Vector2.new(barWidth, fillHeight)
    drawings.healthBar.Color    = getHealthColor(percent)
    drawings.healthBar.Visible  = true
end

