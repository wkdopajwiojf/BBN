local function updateESP(folder, folderName, localFolder)
    local config = FOLDER_CONFIG[folderName]

    for _, child in ipairs(folder:GetChildren()) do
        if child.Name == LocalPlayer.Name then
            removeDrawings(child.Name)
            continue
        end

        local player = Players:FindFirstChild(child.Name)
        if not player or not player.Character then
            removeDrawings(child.Name)
            continue
        end

        local drawColor
        if folder == LOBBY_FOLDER then
            drawColor = WHITE
        elseif localFolder == folder then
            drawColor = BLUE
        else
            drawColor = RED
        end

        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        local pos, size, screenTop, screenBottom = getBoxBounds(hrp.Position, config.top, config.bottom)
        local drawings = getDrawings(child.Name)

        if pos and size then
            updateBox(drawings, pos, size, drawColor)
            updateDistance(drawings, screenBottom, drawColor, hrp.Position)
            updateName(drawings, screenTop, drawColor, player)
            updateHealth(drawings, pos, size, player.Character)
        else
            drawings.box.Visible       = false
            drawings.distance.Visible  = false
            drawings.name.Visible      = false
            drawings.healthBg.Visible  = false
            drawings.healthBar.Visible = false
        end
    end
end

