local function getLocalPlayerFolder()
    for _, folder in ipairs({ALIVE_FOLDER, KILLER_FOLDER, LOBBY_FOLDER}) do
        for _, child in ipairs(folder:GetChildren()) do
            if child.Name == LocalPlayer.Name then
                return folder
            end
        end
    end
    return nil
end

local function getBoxBounds(position, topOffset, bottomOffset)
    local top    = position + Vector3.new(0, topOffset, 0)
    local bottom = position - Vector3.new(0, bottomOffset, 0)

    local topScreen,    topVisible    = Camera:WorldToViewportPoint(top)
    local bottomScreen, bottomVisible = Camera:WorldToViewportPoint(bottom)

    if not topVisible and not bottomVisible then return nil end

    local screenTop    = Vector2.new(topScreen.X, topScreen.Y)
    local screenBottom = Vector2.new(bottomScreen.X, bottomScreen.Y)

    local boxHeight = math.abs(screenBottom.Y - screenTop.Y)
    local boxWidth  = boxHeight * 0.5

    return Vector2.new(screenTop.X - boxWidth / 2, screenTop.Y), Vector2.new(boxWidth, boxHeight), screenTop, screenBottom
end

local function getDistanceFromLocal(position)
    local localHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not localHRP then return nil end
    return math.floor((position - localHRP.Position).Magnitude)
end

local function getModelCenter(model)
    local ok, cf = pcall(function() return model:GetBoundingBox() end)
    if ok then return cf.Position end
    local hrp = model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart
    if hrp then return hrp.Position end
    return nil
end

local function getHealth(character)
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return nil, nil end
    return humanoid.Health, humanoid.MaxHealth
end

local function getHealthColor(percent)
    if percent > 0.5 then
        return Color3.fromRGB(math.floor(255 * (1 - percent) * 2), 255, 0)
    else
        return Color3.fromRGB(255, math.floor(255 * percent * 2), 0)
    end
end

